# ─── Shared x402 settings (facilitator + resource-server + wallet must agree) ──
# The EIP-712 domain is derived from these three values; they MUST match across
# the wallet and the facilitator or signatures will not verify.
X402_NETWORK=casper:casper-test
X402_TOKEN_NAME=Casper X402 Token
# Deployed CEP-18 contract package hash. Leave unset to use the demo placeholder
# (offchain settlement only). Required for SETTLE_MODE=onchain.
# X402_TOKEN_CONTRACT=hash-<64 hex>

# ─── Facilitator ──────────────────────────────────────────────────────────────
PORT=3001
# offchain (default) → verify signature + return synthetic settlement ref.
# onchain            → submit CEP-18 transfer_with_authorization (needs contract).
SETTLE_MODE=offchain

# ─── Resource server ────────────────────────────────────────────────────────
# Run with PORT=3002. Seller account that receives payment (account-hash or pubkey hex).
PAY_TO=account-hash-1111111111111111111111111111111111111111111111111111111111111111
FACILITATOR_URL=http://127.0.0.1:3001
# Price in atomic units (9 decimals): 1000000 = 0.001 CSPR
AMOUNT=1000000
# PUBLIC_BASE_URL=http://127.0.0.1:3002
