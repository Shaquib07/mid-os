{
  "name": "x402-casper-core",
  "version": "0.1.0",
  "description": "Shared Casper x402 protocol core — EIP-712 TransferWithAuthorization signing & verification (Ed25519). Single source of truth for the MidOS wallet and facilitator.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@noble/hashes": "^1.4.0",
    "casper-js-sdk": "^5.0.12"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  },
  "license": "MIT"
}
