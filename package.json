{
  "name": "midos-wallet-mcp",
  "version": "0.2.0",
  "description": "MidOS — an MCP wallet that lets AI agents pay for x402-gated APIs on Casper (CSPR + CEP-18, EIP-712 TransferWithAuthorization)",
  "type": "module",
  "workspaces": [
    "packages/*",
    "casper-x402/*"
  ],
  "bin": {
    "midos-wallet-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' '__tests__/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' '__tests__/**/*.ts'",
    "format:fix": "prettier --write 'src/**/*.ts' '__tests__/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "agent": "node agent/run.mjs",
    "verify-deploy": "node scripts/verify-deploy.mjs",
    "facilitator": "npm run start --workspace midos-casper-facilitator",
    "pulse": "npm run start --workspace midos-casper-resource-server",
    "e2e": "node casper-x402/e2e-client.mjs",
    "build:mcpb": "bash scripts/build-mcpb.sh",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "casper-js-sdk": "^5.0.12",
    "x402-casper-core": "*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.21",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.1"
  },
  "keywords": [
    "x402",
    "wallet",
    "mcp",
    "casper",
    "cspr",
    "cep-18",
    "payments",
    "agent-commerce"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR-USERNAME/midos"
  },
  "engines": {
    "node": ">=18"
  }
}
